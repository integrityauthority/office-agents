{
  "name": "office-agents",
  "version": "0.2.4",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "dev-server": "pnpm --filter @office-agents/excel dev-server",
    "start": "pnpm --filter @office-agents/excel start",
    "stop": "pnpm --filter @office-agents/excel stop",
    "lint": "biome check packages/core/src packages/excel/src packages/excel/vite.config.ts",
    "lint:fix": "biome check --write packages/core/src packages/excel/src packages/excel/vite.config.ts",
    "format": "biome format --write packages/core/src packages/excel/src packages/excel/vite.config.ts",
    "test": "pnpm -r test",
    "typecheck": "tsc -b packages/core packages/excel",
    "check": "tsc -b packages/core packages/excel && biome check packages/",
    "validate": "pnpm --filter @office-agents/excel exec office-addin-manifest validate manifest.xml && pnpm --filter @office-agents/excel exec office-addin-manifest validate manifest.prod.xml"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
